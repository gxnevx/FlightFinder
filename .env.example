# FlightFinder — variáveis de ambiente (NOMES apenas, configure os valores no
# painel do Vercel em Project Settings > Environment Variables). NUNCA commite
# valores reais. Tudo é opcional: sem nada configurado, a app roda em modo
# degradado (mock/in-memory) e avisa na UI.

# --- Supabase (persistência). Sem isso, histórico fica só em memória. ---
# Público (pode ir ao client):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Servidor apenas (NUNCA exposto no client bundle):
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_HOST=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# --- Fontes de voo opcionais (token grátis, sem cartão). Sem token, pulam. ---
AWESOMEAPI_TOKEN=
TRAVELPAYOUTS_TOKEN=
AVIATIONSTACK_TOKEN=

# --- Worker externo (Python/browser) para fontes que não rodam no Vercel. ---
# Ex.: https://meu-worker.exemplo/api . Sem isso, voos vêm de mock marcado como demo.
FLIGHT_WORKER_URL=
FLIGHT_WORKER_TOKEN=

# --- Conversão ---
IOF_PCT=3.5
