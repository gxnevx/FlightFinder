{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "AGENT_BROWSER_EXECUTABLE_PATH": "/root/.agent-browser/chrome",
    "AGENT_BROWSER_IGNORE_HTTPS_ERRORS": "true",
    "AGENT_BROWSER_ARGS": "--no-sandbox",

    "SSL_CERT_FILE": "/etc/ssl/certs/ca-certificates.crt",
    "REQUESTS_CA_BUNDLE": "/etc/ssl/certs/ca-certificates.crt",

    "IOF_PCT": "3.5",

    "AWESOMEAPI_TOKEN": "",
    "TRAVELPAYOUTS_TOKEN": "",
    "AVIATIONSTACK_TOKEN": ""
  },
  "permissions": {
    "allow": [
      "Bash(agent-browser:*)",
      "Bash(letsfg:*)",
      "Bash(./bin/flightfinder:*)",
      "Bash(./bin/dolar:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/setup-flightfinder.sh\""
          }
        ]
      }
    ]
  }
}
